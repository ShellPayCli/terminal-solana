# ============================================
#   ShellPayCli - Environment Configuration
# ============================================

# OpenAI API Key (required for AI chat assistant)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# OpenAI model to use (optional, defaults to gpt-4o)
OPENAI_MODEL=gpt-4o

# Solana network: mainnet-beta | devnet | testnet (defaults to mainnet-beta)
SOLANA_NETWORK=mainnet-beta

# Custom Solana RPC URL (optional, uses public endpoints by default)
# For production use, consider a dedicated RPC provider like Helius or QuickNode
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Custom SQLite database path (optional)
# Defaults to ~/.shellpaycli/shellpay.db
SHELLPAY_DB_PATH=
